# =============================================================================
# PrepX VPS Production Environment Variables
# =============================================================================
# Copy this file to .env.vps and fill in all values before running:
#   cp .env.vps.example .env.vps
# =============================================================================

# -------------------------------------------------------------------------
# Base Configuration
# -------------------------------------------------------------------------
APP_DOMAIN=aimasteryedu.in
ADMIN_EMAIL=admin@aimasteryedu.in
NEXT_PUBLIC_APP_URL=https://aimasteryedu.in
TZ=Asia/Kolkata

# -------------------------------------------------------------------------
# Supabase Self-Hosted
# -------------------------------------------------------------------------
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD_32CHARS
POSTGRES_PORT=5432

JWT_SECRET=CHANGE_ME_TO_A_64CHAR_RANDOM_STRING
ANON_KEY=CHANGE_ME_TO_A_64CHAR_RANDOM_STRING
SERVICE_ROLE_KEY=CHANGE_ME_TO_A_64CHAR_RANDOM_STRING

DB_ENC_KEY=CHANGE_ME_32CHAR_HEX
SECRET_KEY_BASE=CHANGE_ME_64CHAR_HEX

NEXT_PUBLIC_SUPABASE_URL=https://supabase.aimasteryedu.in
NEXT_PUBLIC_SUPABASE_ANON_KEY=${ANON_KEY}

# -------------------------------------------------------------------------
# Redis
# -------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -------------------------------------------------------------------------
# MinIO / S3 Storage (CDN)
# -------------------------------------------------------------------------
MINIO_ROOT_USER=prepxminio
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_ADMIN_32CHARS
S3_BUCKET=prepx
S3_ENDPOINT=http://minio:9000

IMGPROXY_KEY=CHANGE_ME_32CHAR_HEX
IMGPROXY_SALT=CHANGE_ME_32CHAR_HEX

# -------------------------------------------------------------------------
# Razorpay Payments
# -------------------------------------------------------------------------
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_YOUR_KEY_HERE
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET_HERE
RAZORPAY_WEBHOOK_SECRET=YOUR_RAZORPAY_WEBHOOK_SECRET_HERE

# -------------------------------------------------------------------------
# AI Providers
# -------------------------------------------------------------------------
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_API_KEY=ollama

NINEROUTER_BASE_URL=https://api.9router.ai/v1
NINEROUTER_API_KEY=YOUR_KEY_HERE

OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE

# -------------------------------------------------------------------------
# Email / SMTP (SendGrid)
# -------------------------------------------------------------------------
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=YOUR_SENDGRID_API_KEY
SMTP_FROM=noreply@aimasteryedu.in

# -------------------------------------------------------------------------
# Twilio SMS
# -------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=AC_YOUR_TWILIO_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_MESSAGING_SID=MG_YOUR_MESSAGING_SERVICE_SID

# -------------------------------------------------------------------------
# Sentry Error Tracking
# -------------------------------------------------------------------------
SENTRY_DSN=https://YOUR_SENTRY_KEY@sentry.io/PROJECT_ID

# -------------------------------------------------------------------------
# Crawl4AI
# -------------------------------------------------------------------------
CRAWL4AI_API_TOKEN=YOUR_CRAWL4AI_TOKEN

# -------------------------------------------------------------------------
# n8n
# -------------------------------------------------------------------------
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_N8N_32CHARS
N8N_DB_PASSWORD=CHANGE_ME_N8N_DB_32CHARS

# -------------------------------------------------------------------------
# Mautic
# -------------------------------------------------------------------------
MAUTIC_DB_PASSWORD=CHANGE_ME_MAUTIC_DB_32CHARS
MAUTIC_DB_ROOT_PASSWORD=CHANGE_ME_MAUTIC_ROOT_32CHARS
MAUTIC_ADMIN_USER=admin
MAUTIC_ADMIN_PASS=CHANGE_ME_MAUTIC_ADMIN_32CHARS

# -------------------------------------------------------------------------
# Plausible Analytics
# -------------------------------------------------------------------------
PLAUSIBLE_SECRET=CHANGE_ME_PLAUSIBLE_64CHARS
PLAUSIBLE_DB_PASSWORD=CHANGE_ME_PLAUSIBLE_DB_32CHARS

# -------------------------------------------------------------------------
# Grafana
# -------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_32CHARS

# -------------------------------------------------------------------------
# Kong API Gateway
# -------------------------------------------------------------------------
KONG_DASHBOARD_USER=admin
KONG_DASHBOARD_PASS=CHANGE_ME_KONG_32CHARS

# -------------------------------------------------------------------------
# Admin API Key (for admin routes)
# -------------------------------------------------------------------------
ADMIN_API_KEY=CHANGE_ME_ADMIN_API_KEY_64CHARS
